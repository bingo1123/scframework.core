<Window x:Class="ModbusReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="在线水分仪数据监控" 
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        Loaded="Window_Loaded" WindowStyle="None">
    
    <Window.Resources>
        <!-- 状态颜色 -->
        <SolidColorBrush x:Key="SuccessColor" Color="#FF4CAF50"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#FFF44336"/>
        <SolidColorBrush x:Key="WarningColor" Color="#FFFFC107"/>
        <SolidColorBrush x:Key="InfoColor" Color="#FF2196F3"/>
        
        <!-- 数据网格样式 -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FFF0F5FF"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FFF5F9FF"/>
            <Setter Property="BorderBrush" Value="#FFBBDEFB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowDetailsVisibilityMode" Value="VisibleWhenSelected"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="true"/>
            <Setter Property="ScrollViewer.PanningMode" Value="Both"/>
            <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="True"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
        </Style>
        
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE3F2FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFBBDEFB"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 按钮样式 -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF1E88E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF1976D2"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF0D47A1"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFBBDEFB"/>
                    <Setter Property="Foreground" Value="#FF757575"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#FF1E88E5" Height="40">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Image Source="Resources/modbus.png" Width="24" Height="24" Margin="10,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="在线水分仪数据监控" 
                           Foreground="White" FontSize="16" FontWeight="Bold" 
                           VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="btnMinimize" Content="_" Width="30" Click="MinimizeButton_Click" 
                            Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16"/>
                    <Button x:Name="btnMaximize" Content="□" Width="30" Click="MaximizeButton_Click" 
                            Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16"/>
                    <Button x:Name="btnClose" Content="×" Width="30" Click="CloseButton_Click" 
                            Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 主内容区 -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- 控制面板 -->
            <Border Grid.Row="0" CornerRadius="4" Background="White" Padding="10" 
                    BorderBrush="#FFE0E0E0" BorderThickness="1" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name ="MachineName"  Text="机台名称:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Button x:Name="btnConnect" Content="连接设备" IsEnabled="False" Width="100" Height="36" Click="BtnConnect_Click"/>
                    <Button x:Name="btnDisconnect" Content="断开连接" Width="100" Height="36" IsEnabled="False" Click="BtnDisconnect_Click"/>
                    <Separator Width="20" Opacity="0"/>
                    <Button x:Name="btnRead" Content="读取数据" Width="100" Height="36" IsEnabled="False" Click="BtnRead_Click"/>
                    <Button x:Name="btnAutoRead" Content="自动读取" Width="100" Height="36" IsEnabled="False" Click="BtnAutoRead_Click"/>
                    <Separator Width="20" Opacity="0"/>
                    <TextBlock Text="读取间隔:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="cmbReadInterval" Width="80" Height="36" IsEnabled="False" SelectedIndex="0" VerticalContentAlignment="Center">
                        <ComboBoxItem>1秒</ComboBoxItem>
                        <ComboBoxItem>2秒</ComboBoxItem>
                        <ComboBoxItem>5秒</ComboBoxItem>
                        <ComboBoxItem>10秒</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </Border>
            
            <!-- 数据展示 -->
            <Border Grid.Row="1" CornerRadius="4" Background="White" 
                    BorderBrush="#FFE0E0E0" BorderThickness="1">
                <DataGrid x:Name="dataGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="120"/>
                        <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="180"/>
                        <DataGridTextColumn Header="地址" Binding="{Binding Address}" Width="80"/>
                        <DataGridTextColumn Header="寄存器类型" Binding="{Binding RegisterType}" Width="100"/>
                        <DataGridTextColumn Header="数据类型" Binding="{Binding DataType}" Width="80"/>
                        <DataGridTextColumn Header="值" Binding="{Binding Value}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="60"/>
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="成功">
                                            <Setter Property="Foreground" Value="{StaticResource SuccessColor}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="未读取">
                                            <Setter Property="Foreground" Value="{StaticResource WarningColor}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="错误">
                                            <Setter Property="Foreground" Value="{StaticResource ErrorColor}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="更新时间" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
        
        <!-- 状态栏 -->
        <StatusBar Grid.Row="2" Background="#FFE3F2FD">
            <StatusBarItem>
                <TextBlock x:Name="txtConnectionStatus" Text="未连接" Margin="5,0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="txtDeviceStatus" Text="设备: -" Margin="5,0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="txtLastUpdate" Text="最后更新: -" Margin="5,0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>读取进度:</TextBlock>
            </StatusBarItem>
            <StatusBarItem>
                <ProgressBar x:Name="progressStatus" Width="100" Height="16" IsIndeterminate="False"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="txtDataCount" Text="0/0 点" Margin="5,0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="txtErrorCount" Text="错误: 0" Margin="5,0" Foreground="{StaticResource ErrorColor}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>