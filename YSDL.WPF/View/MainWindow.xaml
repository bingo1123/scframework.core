<Window
	x:Class="YSDL.WPF.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:local="clr-namespace:YSDL.WPF" xmlns:helper="clr-namespace:YSDL.src.HelperControllers;assembly=YSDL" xmlns:ViewModel="clr-namespace:YSDL.WPF.ViewModel" xmlns:sys="clr-namespace:System;assembly=mscorlib"
	WindowStartupLocation="CenterScreen"
	Title="卷包边缘数采工具"
	Height="600"
	Width="1200"
	Background="#FFFFFFFF">
    <FrameworkElement.DataContext>
        <ViewModel:MainViewModel />
    </FrameworkElement.DataContext>
    <Grid
		Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition
				Height="400" />
            <RowDefinition
				Height="*" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition
					Width="380" />
                <ColumnDefinition
					Width="*" />
                <ColumnDefinition
					Width="380" />
            </Grid.ColumnDefinitions>
            <Border
				Grid.Column="0"
				Margin="8"
				Background="#FFF5F5F5"
				CornerRadius="12"
				Padding="12">
                <StackPanel>
                    <TextBlock
						Text="设备连接"
						FontSize="18"
						FontWeight="Bold"
						Foreground="{DynamicResource MaterialDesignBody}"
						Margin="0,0,0,8" />
                    <UniformGrid
						Columns="2"
						Rows="3"
						Margin="0,0,0,8">
                        <TextBlock
							Text="设备IP地址:"
							FontSize="16"
							Foreground="{DynamicResource MaterialDesignBody}"
							VerticalAlignment="Center" />
                        <TextBox
							FontSize="16"
							Background="#FFFFFFFF"
							Text="{Binding IpAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock
							Text="设备端口:"
							FontSize="16"
							Foreground="{DynamicResource MaterialDesignBody}"
							VerticalAlignment="Center" />
                        <TextBox
							FontSize="16"
							Background="#FFFFFFFF"
							Text="{Binding Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button
							Content="连接"
							FontSize="16"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="true"
							Margin="0,0,8,0"
							Command="{Binding ConnectCommand}"
							IsEnabled="{Binding Isdisconnect}" />
                        <Button
							Name="con"
							Content="断开连接"
							FontSize="16"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="false"
							Command="{Binding ConnectCommand}"
							IsEnabled="{Binding Isconnect}" />
                    </UniformGrid>
                    <Separator
						Margin="0,8" />
                    <UniformGrid
						Columns="2"
						Rows="5">
                        <TextBlock
							Text="符号地址:"
							FontSize="16"
							Foreground="{DynamicResource MaterialDesignBody}"
							VerticalAlignment="Center" />
                        <TextBox
							FontSize="12"
							Background="#FFFFFFFF"
							Text="{Binding SymbAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock
							Text="节点地址:"
							FontSize="16"
							Foreground="{DynamicResource MaterialDesignBody}"
							VerticalAlignment="Center" />
                        <TextBox
							FontSize="16"
							Background="#FFFFFFFF"
							Text="{Binding NodeAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock
							Text="功能地址:"
							FontSize="16"
							Foreground="{DynamicResource MaterialDesignBody}"
							VerticalAlignment="Center" />
                        <TextBox
							FontSize="16"
							Background="#FFFFFFFF"
							Text="{Binding FuncAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock
							Text="参数编号:"
							FontSize="16"
							Foreground="{DynamicResource MaterialDesignBody}"
							VerticalAlignment="Center" />
                        <TextBox
							FontSize="16"
							Background="#FFFFFFFF"
							Text="{Binding ParamNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock
							Text="机台型号:"
							FontSize="16"
							Foreground="{DynamicResource MaterialDesignBody}"
							VerticalAlignment="Center" />
                        <StackPanel
							Orientation="Horizontal">
                            <ComboBox
								Width="120"
								ItemsSource="{Binding ProtocolType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
								SelectedItem="{Binding SelectItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <TextBlock
							Text="写入值:"
							FontSize="16"
							Foreground="{DynamicResource MaterialDesignBody}"
							VerticalAlignment="Center" />
                        <TextBox
							FontSize="16"
							Background="#FFFFFFFF"
							Text="{Binding WriteValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock
							Text="写入值类型:"
							FontSize="16"
							Foreground="{DynamicResource MaterialDesignBody}"
							VerticalAlignment="Center" />
                        <StackPanel
							Orientation="Horizontal">
                            <ComboBox
								Width="120"
								ItemsSource="{Binding ValueType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
								SelectedItem="{Binding ValueTypeItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <TextBlock
							Text="品牌参数:"
							FontSize="16"
							Foreground="{DynamicResource MaterialDesignBody}"
							VerticalAlignment="Center" />
                        <TextBox
							FontSize="16"
							Background="#FFFFFFFF"
							Text="{Binding BrandName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </UniformGrid>
                </StackPanel>
            </Border>
            <Border
				Grid.Column="1"
				Margin="8"
				Background="#FFF5F5F5"
				CornerRadius="12"
				Padding="12">
                <StackPanel>
                    <TextBlock
						Text="数据操作"
						FontSize="18"
						FontWeight="Bold"
						Foreground="{DynamicResource MaterialDesignBody}"
						Margin="0,0,0,8" />
                    <WrapPanel
						Margin="0,0,0,8"
						ItemHeight="40"
						ItemWidth="140">
                        <Button
							Content="Read Data"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="readData"
							Margin="0,0,8,0"
							Command="{Binding ReadDataCommand}" />
                        <Button
							Content="ReadMachine"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="machine"
							Margin="0,0,8,0"
							Command="{Binding ReadDataCommand}" />
                        <Button
							Content="ReadBrand"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="brand"
							Margin="0,0,8,0"
							Command="{Binding ReadDataCommand}" />
                        <Button
							Content="ReadParameter"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="param"
							Margin="0,0,8,0"
							Command="{Binding ReadDataCommand}" />
                        <Button
							Content="读设备参数"
							Style="{StaticResource MaterialDesignRaisedButton}"
							Margin="0,0,8,0"
							Command="{Binding ReadMachineParamAndOutPutNameCommand}" />
                        <Button
							Content="读品牌参数"
							Style="{StaticResource MaterialDesignRaisedButton}"
							Margin="0,0,8,0"
							Command="{Binding ReadBrandParamAndOutPutNameCommand}" />
                        <Button
							Content="WriteMachine"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="machine"
							Margin="0,0,8,0"
							Command="{Binding WriteDataCommand}" />
                        <Button
							Content="WriteBrand"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="brand"
							Margin="0,0,8,0"
							Command="{Binding WriteDataCommand}" />
                    </WrapPanel>
                    <WrapPanel
						Visibility="Collapsed">
                        <Button
							Content="ZB48A单机状态"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="MachineStatus"
							Command="{Binding ReadZB48ADataCommand}" />
                        <Button
							Content="ZB48A机器性能"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="MachinePerformance"
							Command="{Binding ReadZB48ADataCommand}" />
                        <Button
							Content="ZB48A停机信息"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="DeviceFault"
							Command="{Binding ReadZB48ADataCommand}" />
                        <Button
							Content="ZB48A参数当前值"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="DeviceParameter"
							Command="{Binding ReadZB48ADataCommand}" />
                        <Button
							Content="ZB48A停机分析"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="HaltAnalysis"
							Command="{Binding ReadZB48ADataCommand}" />
                        <Button
							Content="ZB48A小时能耗"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="HourConsumption"
							Command="{Binding ReadZB48ADataCommand}" />
                        <Button
							Content="ZB48A不停机报警"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="MalfunctionData"
							Command="{Binding ReadZB48ADataCommand}" />
                        <Button
							Content="ZB48A参数修改记录"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="ParameterModification"
							Command="{Binding ReadZB48ADataCommand}" />
                        <Button
							Content="ZB48A全流程消耗"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="ProcessConsumption"
							Command="{Binding ReadZB48ADataCommand}" />
                        <Button
							Content="ZB48A生产数据"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="ProductionData"
							Command="{Binding ReadZB48ADataCommand}" />
                        <Button
							Content="ZB48A剔除数据"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="RejectData"
							Command="{Binding ReadZB48ADataCommand}" />
                        <Button
							Content="ZB48A实际车速"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="SpeedData"
							Command="{Binding ReadZB48ADataCommand}" />
                    </WrapPanel>
                </StackPanel>
            </Border>
            <Border
				Grid.Column="2"
				Margin="8"
				Background="#FFF5F5F5"
				CornerRadius="12"
				Padding="12">
                <StackPanel>
                    <TextBlock
						Text="设备信息与部署"
						FontSize="18"
						FontWeight="Bold"
						Foreground="{DynamicResource MaterialDesignBody}"
						Margin="0,0,0,8" />
                    <StackPanel
						Orientation="Horizontal"
						Margin="0,0,0,8">
                        <TextBlock
							Text="设备编码:"
							FontSize="16"
							Foreground="{DynamicResource MaterialDesignBody}"
							VerticalAlignment="Center"
							Width="100" />
                        <TextBox
							FontSize="16"
							Background="#FFFFFFFF"
							Width="200"
							Text="{Binding DeviceCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <WrapPanel
						ItemHeight="40"
						ItemWidth="180">
                        <Button
							Content="安装/卸载服务"
							FontSize="16"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="server"
							Command="{Binding RunStartBatCommand}" />
                        <Button
							Content="实时监控"
							FontSize="16"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="false"
							Command="{Binding MonitorCommand}" />
                        <Button
							Content="实时监控测试"
							FontSize="16"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="test"
							Visibility="Hidden"
							Command="{Binding MonitorCommand}" />
                        <Button
							Content="开始采集并上传"
							FontSize="16"
							Style="{StaticResource MaterialDesignRaisedButton}"
							CommandParameter="true"
							Visibility="Hidden"
							Command="{Binding CaijiCommand}" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>
        <Grid
			Row="1">
            <Separator
				Grid.Row="0"
				Margin="0,4" />
            <Border
				CornerRadius="12"
				Margin="0,12,0,0"
				BorderBrush="{DynamicResource MaterialDesignDivider}"
				BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition
							Height="auto" />
                        <RowDefinition
							Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel
						Grid.Row="0"
						Orientation="Horizontal"
						VerticalAlignment="Center">
                        <TextBlock
							Foreground="{DynamicResource MaterialDesignBody}"
							FontSize="18"
							Text="日志"
							Margin="0,0,8,0" />
                        <Button
							Width="20"
							Height="20"
							Margin="0,0,12,0"
							Style="{StaticResource MaterialDesignFloatingActionDarkButton}"
							ToolTip="清空"
							ToolTipService.ShowOnDisabled="True"
							Command="{Binding ClearLogMessageCommand}" />
                    </StackPanel>
                    <ListView
						Grid.Row="1"
						Margin="0,4,0,0"
						ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ScrollViewer
									MaxHeight="200"
									VerticalScrollBarVisibility="Auto">
                                    <TextBlock
										Text="{Binding}">
										<FrameworkElement.ContextMenu>
											<ContextMenu>
												<MenuItem
													Header="复制"
													Command="{Binding CopyMessageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
													CommandParameter="{Binding}" />
											</ContextMenu>
										</FrameworkElement.ContextMenu>
                                    </TextBlock>
                                </ScrollViewer>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
