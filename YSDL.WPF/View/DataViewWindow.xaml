<Window x:Class="YSDL.WPF.View.DataViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:YSDL.WPF.View"
        mc:Ignorable="d"
        Title="DataViewWindow" Height="550" Width="350">
    <Grid>
        <DockPanel>
            <!-- 导出按钮 -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                <Button Content="导出到文本文件" Padding="10,5" Click="Export_Click"/>
            </StackPanel>

            <!-- 数据表格 -->
            <DataGrid x:Name="dataGrid" AutoGenerateColumns="True" 
                  IsReadOnly="True" Margin="10" 
                  HeadersVisibility="Column"/>
        </DockPanel>
    </Grid>
</Window>
